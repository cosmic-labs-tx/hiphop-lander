---
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar.astro";
import "@fontsource-variable/inter/index.css";
import { SEO } from "astro-seo";
import "../tailwind.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const { title, description, image } = Astro.props;

const resolvedImageWithDomain = new URL(image ?? "/opengraph.png", Astro.site).toString();

const makeTitle = title ? title + " | " + "Hip Hop Defensive Driving" : "Hip Hop Defensive Driving";

const defaultDescription = "Hip Hop Defensive Driving is the #1 Music Themed Texas Defensive Driving Course.";
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preload" as="image" href={"/faq-open.svg"} />
    <SEO
      title={makeTitle}
      description={description ?? defaultDescription}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: title || "Hip Hop Defensive Driving",
          image: resolvedImageWithDomain,
        },
        optional: {
          siteName: "Hip Hop Defensive Driving",
          description: description ?? defaultDescription,
        },
        image: {
          alt: title || "Hip Hop Defensive Driving Homepage Screenshot",
        },
      }}
    />
  </head>
  <body class="flex h-full flex-col">
    <Navbar />
    <main class="flex-1"><slot /></main>
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
