---
import logo from "@assets/logo.svg";
import Image from "astro/components/Image.astro";
---

<footer class="mt-16 flex flex-col items-center gap-y-18 bg-neutral-100 py-18">
  <div>
    <Image src={logo} alt="Hip Hop Defensive Driving" class="h-12" />
  </div>
  <div class="flex flex-col gap-6">
    <div class="flex justify-center gap-4 text-sm font-light">
      <a href="/blog">Blog</a>
      <a href="/terms">Terms</a>
      <a href="/support">Support</a>
    </div>
    <p class="text-center text-lg font-medium">
      Plumb Media & Education LLC {new Date().getFullYear()}© All rights reserved.
    </p>
  </div>
</footer>
